# --- Database (MongoDB Atlas) ---
# Atlas already runs as a replica set, which Prisma needs for transactions.
# The cluster connection string (the db name in the path is optional and is
# overridden by DATABASE_NAME below).
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
# Database name — injected into DATABASE_URL at runtime.
DATABASE_NAME="alaki"

# --- Auth (better-auth) ---
# Generate a strong secret, e.g.  openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3001"
# Where the browser app runs (used for CORS + OAuth redirects)
APP_ORIGIN="http://localhost:3000"

# --- Google OAuth ---
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

PORT=3001
